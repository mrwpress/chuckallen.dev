---

<div class="tech-marquee" role="region" aria-label="Technologies and tools">
  <div class="tech-marquee-track">
    {[0, 1].map(() => (
      <div class="tech-marquee-set" aria-hidden={true}>
        {tools.map((tool) => (
          <div class="tech-item">
            <svg viewBox="0 0 24 24" class="tech-icon" aria-hidden="true">
              {tool.paths ? (
                tool.paths.map((seg: {d: string; fill: string}) => (
                  <path d={seg.d} fill={seg.fill} />
                ))
              ) : (
                <path d={tool.path} fill={tool.color} />
              )}
            </svg>
            {tool.coloredLabel ? (
              <span class="tech-label">
                {tool.coloredLabel.map((l: {letter: string; color: string}) => (
                  <span style={`color:${l.color}`}>{l.letter}</span>
                ))}
              </span>
            ) : (
              <span class="tech-label">{tool.name}</span>
            )}
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .tech-marquee {
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    padding: 1.5rem 0;
  }

  .tech-marquee-track {
    display: flex;
    width: max-content;
    animation: tech-scroll 40s linear infinite;
    will-change: transform;
  }

  .tech-marquee:hover .tech-marquee-track {
    animation-play-state: paused;
  }

  .tech-marquee-set {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding-right: 3rem;
  }

  @media (min-width: 768px) {
    .tech-marquee-set {
      gap: 4rem;
      padding-right: 4rem;
    }
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .tech-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .tech-icon {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  .tech-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .tech-label {
      font-size: 0.9375rem;
    }
  }

  @keyframes tech-scroll {
    to {
      transform: translateX(-50%);
    }
  }
</style>
