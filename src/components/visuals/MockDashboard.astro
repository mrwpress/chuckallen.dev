---
interface Props {
  variant?: 'analytics' | 'operations' | 'workflow' | 'project' | 'agency';
}

const { variant = 'analytics' } = Astro.props;

const ariaLabels: Record<string, string> = {
  analytics: 'Analytics dashboard mockup',
  operations: 'Operations dashboard mockup',
  workflow: 'Workflow automation dashboard mockup',
  project: 'Project delivery dashboard mockup',
  agency: 'Agency operations dashboard mockup',
};

const titleBarLabels: Record<string, string> = {
  analytics: 'analytics-dashboard.app',
  operations: 'ops-dashboard.app',
  workflow: 'workflow-monitor.app',
  project: 'project-tracker.app',
  agency: 'agency-portal.app',
};
---

<div class="dashboard-wrap" data-animate>
  <svg viewBox="0 0 560 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="dashboard-svg" role="img" aria-label={ariaLabels[variant]}>
    <!-- Window frame -->
    <rect x="0" y="0" width="560" height="340" rx="12" fill="var(--color-surface)" stroke="var(--color-border-light)" stroke-width="1" />

    <!-- Title bar -->
    <rect x="0" y="0" width="560" height="32" rx="12" fill="var(--color-surface-2)" />
    <rect x="0" y="12" width="560" height="20" fill="var(--color-surface-2)" />
    <line x1="0" y1="32" x2="560" y2="32" stroke="var(--color-border-light)" stroke-width="1" />

    <!-- Traffic light dots -->
    <circle cx="20" cy="16" r="4" fill="#ef4444" opacity="0.8" />
    <circle cx="34" cy="16" r="4" fill="#eab308" opacity="0.8" />
    <circle cx="48" cy="16" r="4" fill="#22c55e" opacity="0.8" />

    <!-- Title bar text -->
    <text x="280" y="20" text-anchor="middle" fill="var(--color-text-muted)" font-size="10" font-family="var(--font-sans)" font-weight="500" opacity="0.6">
      {titleBarLabels[variant]}
    </text>

    {variant === 'analytics' && (
      <>
        <!-- ANALYTICS VARIANT -->

        <!-- Area/Line Chart (left, large) -->
        <g class="dash-el dash-el-1">
          <rect x="16" y="44" width="330" height="180" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="62" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" font-weight="500">Revenue Over Time</text>

          <!-- Y-axis grid lines -->
          <line x1="28" y1="80" x2="334" y2="80" stroke="var(--color-border)" stroke-width="0.5" />
          <line x1="28" y1="110" x2="334" y2="110" stroke="var(--color-border)" stroke-width="0.5" />
          <line x1="28" y1="140" x2="334" y2="140" stroke="var(--color-border)" stroke-width="0.5" />
          <line x1="28" y1="170" x2="334" y2="170" stroke="var(--color-border)" stroke-width="0.5" />
          <line x1="28" y1="200" x2="334" y2="200" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Area gradient -->
          <defs>
            <linearGradient id="area-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.3" />
              <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0.02" />
            </linearGradient>
          </defs>

          <!-- Area fill -->
          <path class="chart-area" d="M28 185 L66 170 L104 175 L142 150 L180 140 L218 120 L256 105 L294 90 L334 78 L334 210 L28 210 Z" fill="url(#area-grad)" />

          <!-- Line -->
          <path class="chart-line" d="M28 185 L66 170 L104 175 L142 150 L180 140 L218 120 L256 105 L294 90 L334 78" stroke="var(--color-accent-light)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />

          <!-- Data dots -->
          <circle cx="180" cy="140" r="3" fill="var(--color-accent-light)" class="chart-dot" />
          <circle cx="256" cy="105" r="3" fill="var(--color-accent-light)" class="chart-dot" />
          <circle cx="334" cy="78" r="3" fill="var(--color-accent-light)" class="chart-dot" />

          <!-- X-axis labels -->
          <text x="28" y="218" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Jan</text>
          <text x="104" y="218" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Mar</text>
          <text x="180" y="218" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">May</text>
          <text x="256" y="218" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Jul</text>
          <text x="334" y="218" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Sep</text>
        </g>

        <!-- Bar Chart (top right) -->
        <g class="dash-el dash-el-2">
          <rect x="358" y="44" width="186" height="112" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="370" y="62" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" font-weight="500">Conversions</text>

          <!-- Bars -->
          <rect class="bar bar-1" x="378" y="130" width="20" height="0" rx="2" fill="var(--color-accent)" opacity="0.5" />
          <rect class="bar bar-2" x="406" y="130" width="20" height="0" rx="2" fill="var(--color-accent)" opacity="0.65" />
          <rect class="bar bar-3" x="434" y="130" width="20" height="0" rx="2" fill="var(--color-accent)" opacity="0.8" />
          <rect class="bar bar-4" x="462" y="130" width="20" height="0" rx="2" fill="var(--color-accent-light)" opacity="0.9" />
          <rect class="bar bar-5" x="490" y="130" width="20" height="0" rx="2" fill="var(--color-accent-light)" />

          <!-- Bar labels -->
          <text x="388" y="146" text-anchor="middle" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Mon</text>
          <text x="416" y="146" text-anchor="middle" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Tue</text>
          <text x="444" y="146" text-anchor="middle" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Wed</text>
          <text x="472" y="146" text-anchor="middle" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Thu</text>
          <text x="500" y="146" text-anchor="middle" fill="var(--color-text-muted)" font-size="7" font-family="var(--font-sans)" opacity="0.5">Fri</text>
        </g>

        <!-- Donut Chart (bottom right) -->
        <g class="dash-el dash-el-3">
          <rect x="358" y="168" width="186" height="156" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="370" y="186" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" font-weight="500">Traffic Sources</text>

          <!-- Donut segments -->
          <circle cx="451" cy="268" r="40" fill="none" stroke="var(--color-surface)" stroke-width="14" />
          <circle class="donut donut-1" cx="451" cy="268" r="40" fill="none" stroke="var(--color-accent-light)" stroke-width="14" stroke-dasharray="0 251.3" stroke-linecap="round" transform="rotate(-90 451 268)" />
          <circle class="donut donut-2" cx="451" cy="268" r="40" fill="none" stroke="var(--color-accent)" stroke-width="14" stroke-dasharray="0 251.3" stroke-linecap="round" transform="rotate(40 451 268)" />
          <circle class="donut donut-3" cx="451" cy="268" r="40" fill="none" stroke="var(--color-text-muted)" stroke-width="14" stroke-dasharray="0 251.3" opacity="0.3" stroke-linecap="round" transform="rotate(160 451 268)" />

