          <rect x="16" y="44" width="130" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Active Workflows</text>
          <text x="28" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">24</text>
          <text x="28" y="106" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">All running</text>

          <rect x="154" y="44" width="130" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="166" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Tasks Today</text>
          <text x="166" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">1,847</text>
          <text x="166" y="106" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">+312 vs yesterday</text>

          <rect x="292" y="44" width="130" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="304" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Time Saved (wk)</text>
          <text x="304" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">14.2h</text>
          <text x="304" y="106" fill="var(--color-accent-light)" font-size="8" font-family="var(--font-sans)" font-weight="600">vs manual process</text>

          <rect x="430" y="44" width="114" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="442" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Errors Caught</text>
          <text x="442" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">7</text>
          <text x="442" y="106" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">Auto-resolved</text>
        </g>

        <!-- Pipeline status list -->
        <g class="dash-el dash-el-2">
          <rect x="16" y="144" width="330" height="180" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="164" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" font-weight="500">Workflow Pipeline</text>

          <text x="28" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">WORKFLOW</text>
          <text x="200" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">LAST RUN</text>
          <text x="300" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">STATUS</text>
          <line x1="28" y1="192" x2="334" y2="192" stroke="var(--color-border)" stroke-width="0.5" />

