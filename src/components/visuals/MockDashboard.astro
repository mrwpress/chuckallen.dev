<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-animate]').forEach((wrap) => {
      if (wrap.closest('[data-animated]')) return;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            wrap.classList.add('visible');
            wrap.setAttribute('data-animated', '');
            observer.unobserve(wrap);
          }
        });
      }, { threshold: 0.15 });
      observer.observe(wrap);
    });
  });
</script>

<style>
  .dashboard-wrap {
    width: 100%;
  }

  .dashboard-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.4));
    border-radius: var(--radius-lg);
  }

  /* --- Elements fade in --- */
  .dash-el {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .visible .dash-el {
    opacity: 1;
    transform: translateY(0);
  }

  .visible .dash-el-1 { transition-delay: 0.1s; }
  .visible .dash-el-2 { transition-delay: 0.3s; }
  .visible .dash-el-3 { transition-delay: 0.5s; }
  .visible .dash-el-4 { transition-delay: 0.7s; }

  /* --- Line chart draw-in --- */
  .chart-line {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    transition: stroke-dashoffset 1.2s ease;
  }

  .visible .chart-line {
    stroke-dashoffset: 0;
    transition-delay: 0.3s;
  }

  .chart-area {
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .visible .chart-area {
    opacity: 1;
    transition-delay: 0.8s;
  }

  .chart-dot {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .visible .chart-dot {
    opacity: 1;
    transition-delay: 1.2s;
  }

  /* --- Bar chart grow --- */
  .bar {
    transform-origin: bottom;
    transition: height 0.6s ease, y 0.6s ease;
  }

  .visible .bar-1 { height: 35; y: 95; transition-delay: 0.4s; }
  .visible .bar-2 { height: 45; y: 85; transition-delay: 0.5s; }
  .visible .bar-3 { height: 40; y: 90; transition-delay: 0.6s; }
  .visible .bar-4 { height: 55; y: 75; transition-delay: 0.7s; }
  .visible .bar-5 { height: 60; y: 70; transition-delay: 0.8s; }
  .visible .bar-6 { height: 70; y: 240; transition-delay: 0.9s; }
  .visible .bar-7 { height: 85; y: 225; transition-delay: 1.0s; }
  .visible .bar-8 { height: 55; y: 255; transition-delay: 1.1s; }

  /* --- Donut chart fill --- */
  .donut {
    transition: stroke-dasharray 1s ease;
  }

  .visible .donut-1 {
    stroke-dasharray: 90 251.3;
    transition-delay: 0.6s;
  }

  .visible .donut-2 {
    stroke-dasharray: 55 251.3;
    transition-delay: 0.8s;
  }

  .visible .donut-3 {
    stroke-dasharray: 40 251.3;
    transition-delay: 1.0s;
  }
</style>
