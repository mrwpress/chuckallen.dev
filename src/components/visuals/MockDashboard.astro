        <!-- KPI row (bottom left) -->
        <g class="dash-el dash-el-4">
          <!-- KPI 1 -->
          <rect x="16" y="236" width="103" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="258" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Bounce Rate</text>
          <text x="28" y="280" fill="var(--color-text)" font-size="18" font-family="var(--font-sans)" font-weight="700">32%</text>
          <text x="28" y="296" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">-4.2%</text>

          <!-- KPI 2 -->
          <rect x="127" y="236" width="103" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="139" y="258" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Avg Session</text>
          <text x="139" y="280" fill="var(--color-text)" font-size="18" font-family="var(--font-sans)" font-weight="700">4:32</text>
          <text x="139" y="296" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">+12.8%</text>

          <!-- KPI 3 -->
          <rect x="238" y="236" width="108" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="250" y="258" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Conversions</text>
          <text x="250" y="280" fill="var(--color-text)" font-size="18" font-family="var(--font-sans)" font-weight="700">847</text>
          <text x="250" y="296" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">+23.1%</text>
        </g>
      </>
    )}

    {variant === 'operations' && (
      <>
        <!-- OPERATIONS VARIANT -->

        <!-- KPI Cards (top row) -->
        <g class="dash-el dash-el-1">
          <!-- KPI 1 -->
          <rect x="16" y="44" width="170" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Open Orders</text>
          <text x="28" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">1,247</text>
          <text x="28" y="106" fill="var(--color-accent-light)" font-size="8" font-family="var(--font-sans)" font-weight="600">+89 today</text>
          <!-- Sparkline -->
          <polyline points="110,96 118,90 126,92 134,85 142,80 150,82 158,74 166,70 174,68" fill="none" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6" stroke-linecap="round" stroke-linejoin="round" />

          <!-- KPI 2 -->
          <rect x="195" y="44" width="170" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="207" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Avg Fulfillment</text>
          <text x="207" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">2.1d</text>
          <text x="207" y="106" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">-0.4d vs last week</text>
          <!-- Sparkline -->
          <polyline points="289,70 297,74 305,72 313,78 321,82 329,76 337,74 345,70 353,68" fill="none" stroke="#22c55e" stroke-width="1.5" opacity="0.6" stroke-linecap="round" stroke-linejoin="round" />

          <!-- KPI 3 -->
          <rect x="374" y="44" width="170" height="88" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="386" y="64" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">Revenue (MTD)</text>
          <text x="386" y="88" fill="var(--color-text)" font-size="22" font-family="var(--font-sans)" font-weight="700">$284k</text>
          <text x="386" y="106" fill="#22c55e" font-size="8" font-family="var(--font-sans)" font-weight="600">92% of target</text>
          <!-- Sparkline -->
          <polyline points="468,96 476,90 484,88 492,82 500,78 508,76 516,72 524,68 532,64" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" opacity="0.6" stroke-linecap="round" stroke-linejoin="round" />
        </g>

        <!-- Mini Table (bottom left) -->
        <g class="dash-el dash-el-2">
          <rect x="16" y="144" width="330" height="180" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" />
          <text x="28" y="164" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" font-weight="500">Recent Orders</text>

          <!-- Table header -->
          <text x="28" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">ORDER</text>
          <text x="130" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">CUSTOMER</text>
          <text x="250" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6">STATUS</text>
          <text x="318" y="186" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)" font-weight="600" opacity="0.6" text-anchor="end">TOTAL</text>
          <line x1="28" y1="192" x2="334" y2="192" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Row 1 -->
          <text x="28" y="210" fill="var(--color-text-secondary, #d6d6d6)" font-size="9" font-family="var(--font-sans)">#4891</text>
          <text x="130" y="210" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)">Acme Corp</text>
          <rect x="250" y="200" width="48" height="16" rx="8" fill="#22c55e" opacity="0.15" />
          <text x="274" y="212" text-anchor="middle" fill="#22c55e" font-size="7" font-family="var(--font-sans)" font-weight="600">Shipped</text>
          <text x="318" y="210" fill="var(--color-text)" font-size="9" font-family="var(--font-sans)" font-weight="600" text-anchor="end">$3,240</text>
          <line x1="28" y1="220" x2="334" y2="220" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Row 2 -->
          <text x="28" y="238" fill="var(--color-text-secondary, #d6d6d6)" font-size="9" font-family="var(--font-sans)">#4890</text>
          <text x="130" y="238" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)">Bolt Industries</text>
          <rect x="250" y="228" width="54" height="16" rx="8" fill="var(--color-accent)" opacity="0.15" />
          <text x="277" y="240" text-anchor="middle" fill="var(--color-accent-light)" font-size="7" font-family="var(--font-sans)" font-weight="600">Processing</text>
          <text x="318" y="238" fill="var(--color-text)" font-size="9" font-family="var(--font-sans)" font-weight="600" text-anchor="end">$8,750</text>
          <line x1="28" y1="248" x2="334" y2="248" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Row 3 -->
          <text x="28" y="266" fill="var(--color-text-secondary, #d6d6d6)" font-size="9" font-family="var(--font-sans)">#4889</text>
          <text x="130" y="266" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)">Peak Logistics</text>
          <rect x="250" y="256" width="48" height="16" rx="8" fill="#22c55e" opacity="0.15" />
          <text x="274" y="268" text-anchor="middle" fill="#22c55e" font-size="7" font-family="var(--font-sans)" font-weight="600">Shipped</text>
          <text x="318" y="266" fill="var(--color-text)" font-size="9" font-family="var(--font-sans)" font-weight="600" text-anchor="end">$1,920</text>
          <line x1="28" y1="276" x2="334" y2="276" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Row 4 -->
          <text x="28" y="294" fill="var(--color-text-secondary, #d6d6d6)" font-size="9" font-family="var(--font-sans)">#4888</text>
          <text x="130" y="294" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)">Summit Health</text>
          <rect x="250" y="284" width="46" height="16" rx="8" fill="#eab308" opacity="0.15" />
          <text x="273" y="296" text-anchor="middle" fill="#eab308" font-size="7" font-family="var(--font-sans)" font-weight="600">Pending</text>
          <text x="318" y="294" fill="var(--color-text)" font-size="9" font-family="var(--font-sans)" font-weight="600" text-anchor="end">$5,100</text>
