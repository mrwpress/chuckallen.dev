          <text x="451" y="265" text-anchor="middle" fill="var(--color-text)" font-size="14" font-family="var(--font-sans)" font-weight="700">2.4k</text>
          <text x="451" y="278" text-anchor="middle" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">visitors</text>
