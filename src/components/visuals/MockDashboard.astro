          <!-- Legend -->
          <circle cx="380" y="186" r="4" fill="#22c55e" cx="380" cy="186" />
          <text x="390" y="190" fill="var(--color-text-muted)" font-size="8" font-family="var(--font-sans)">On Time (94%)</text>
          <circle cx="380" cy="202" r="4" fill="var(--color-accent)" />
