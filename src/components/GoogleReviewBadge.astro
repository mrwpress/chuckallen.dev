---
import reviewsData from '../data/reviews.json';

const hasReviews = reviewsData && typeof reviewsData.rating === 'number' && reviewsData.count > 0;
const rating = hasReviews ? reviewsData.rating.toFixed(1) : '';
const count = hasReviews ? reviewsData.count : 0;
const mapsUrl = hasReviews ? reviewsData.mapsUrl : '#';
---

{hasReviews && (
  <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="g-badge" aria-label={`Rated ${rating} out of 5 on Google — ${count} reviews`}>
    <div class="g-badge-inner">
      <div class="g-badge-left">
        <svg class="g-logo" viewBox="0 0 48 48" aria-hidden="true">
          <path d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" fill="#FFC107"/>
          <path d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" fill="#FF3D00"/>
          <path d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0124 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" fill="#4CAF50"/>
          <path d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 01-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" fill="#1976D2"/>
        </svg>
        <div class="g-badge-info">
          <span class="g-badge-label">Google Reviews</span>
          <div class="g-badge-stars">
            <span class="g-badge-rating">{rating}</span>
            <div class="g-stars" aria-hidden="true">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class="g-star" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div class="g-badge-count">
        <span class="g-badge-count-num">{count}</span>
        <span class="g-badge-count-label">reviews</span>
      </div>
    </div>
  </a>
)}

<style>
  .g-badge {
    display: inline-flex;
    text-decoration: none;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1.25rem;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
    cursor: pointer;
  }
  .g-badge:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.03));
    transform: translateY(-1px);
  }

  .g-badge-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .g-badge-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .g-logo {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .g-badge-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .g-badge-label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .g-badge-stars {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .g-badge-rating {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .g-stars {
    display: flex;
    gap: 1px;
  }

  .g-star {
    width: 16px;
    height: 16px;
    fill: #facc15;
  }

  .g-badge-count {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-left: 1.25rem;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .g-badge-count-num {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .g-badge-count-label {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 500;
  }

  @media (max-width: 639px) {
    .g-badge {
      padding: 0.625rem 1rem;
    }
    .g-badge-inner {
      gap: 1rem;
    }
    .g-logo {
      width: 28px;
      height: 28px;
    }
    .g-badge-rating {
      font-size: 1.125rem;
    }
    .g-badge-count-num {
      font-size: 1.25rem;
    }
    .g-badge-count {
      padding-left: 1rem;
    }
    .g-star {
      width: 14px;
      height: 14px;
    }
  }
</style>
