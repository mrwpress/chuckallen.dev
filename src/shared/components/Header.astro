---
import type { SiteConfig } from '../utils/config';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<header class="site-header">
  <div class="header-inner section-container">

    <!-- Mobile: hamburger button -->
    <button
      class="hamburger"
      aria-label="Toggle menu"
      aria-expanded="false"
      id="mobile-menu-toggle"
    >
      <span class="hamburger-bar" id="hamburger-top" style="transform: translateY(-4px);"></span>
      <span class="hamburger-bar" id="hamburger-mid"></span>
      <span class="hamburger-bar" id="hamburger-bot" style="transform: translateY(4px);"></span>
    </button>

    <!-- Desktop: navigation -->
    <nav class="nav-desktop" aria-label="Main navigation">
      {site.navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>

    <!-- Center: logo -->
    <a href="/" class="header-logo" aria-label={`${site.name} home`}>
      <slot name="logo" />
    </a>

    <!-- Right: email CTA -->
    <a href={`mailto:${site.email}`} class="header-cta header-cta--desktop">
      <svg class="header-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
      </svg>
      {site.email}
    </a>

    <!-- Mobile: email icon only -->
    <a href={`mailto:${site.email}`} class="header-cta header-cta--mobile" aria-label="Email us">
      <svg class="header-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
      </svg>
    </a>

  </div>
</header>

<!-- Mobile slide-out nav -->
<div class="mobile-overlay" id="mobile-nav-overlay">
  <div class="mobile-backdrop" id="mobile-nav-backdrop"></div>
  <nav class="mobile-nav" aria-label="Mobile navigation" id="mobile-nav">
    {site.navItems.map((item) => (
      <a href={item.href} class="mobile-nav-link">{item.label}</a>
    ))}
    <a href={`mailto:${site.email}`} class="mobile-nav-email">
      <svg class="mobile-nav-email-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
      </svg>
      {site.email}
    </a>
  </nav>
</div>

<style>
  /* ── Header ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: 72px;
    display: flex;
    align-items: center;
    overflow: visible;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  @media (min-width: 950px) {
    .site-header {
      height: 98px;
    }
  }

  .header-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Hamburger ── */
  .hamburger {
    position: relative;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    z-index: 60;
    cursor: pointer;
    background: none;
    border: none;
  }
  @media (min-width: 950px) {
    .hamburger {
      display: none;
    }
  }

  .hamburger-bar {
    position: absolute;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  /* ── Desktop nav ── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 24px;
  }
  @media (min-width: 950px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.5;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-text-muted);
  }

  /* ── Logo (centered) ── */
  .header-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  /* ── Email CTA ── */
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 16px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: var(--color-surface);
    transition: border-color 0.2s ease;
  }
  .header-cta:hover {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .header-cta--desktop {
    display: none;
    padding: 0 33px;
    height: 56px;
  }
  @media (min-width: 950px) {
    .header-cta--desktop {
      display: inline-flex;
    }
  }

  .header-cta--mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    padding: 0;
  }
  @media (min-width: 950px) {
    .header-cta--mobile {
      display: none;
    }
  }

  .header-cta-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }
  .header-cta--mobile .header-cta-icon {
    width: 20px;
    height: 20px;
  }

  /* ── Mobile overlay ── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    pointer-events: none;
  }
  @media (min-width: 950px) {
    .mobile-overlay {
      display: none;
    }
  }

  .mobile-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-nav {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    display: flex;
    flex-direction: column;
    padding: 96px 24px 32px;
    background: var(--color-surface);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  .mobile-nav-link {
    display: block;
    padding: 16px;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .mobile-nav-link:hover {
    color: var(--color-text);
  }

  .mobile-nav-email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 12px 16px;
    font-size: 14px;
    color: var(--color-text-secondary, #d6d6d6);
    transition: color 0.2s ease;
  }
  .mobile-nav-email:hover {
    color: var(--color-text);
  }

  .mobile-nav-email-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    opacity: 0.6;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const overlay = document.getElementById('mobile-nav-overlay');
    const backdrop = document.getElementById('mobile-nav-backdrop');
    const nav = document.getElementById('mobile-nav');
    const top = document.getElementById('hamburger-top');
    const mid = document.getElementById('hamburger-mid');
    const bot = document.getElementById('hamburger-bot');
    let open = false;

    function setMenu(state: boolean) {
      open = state;
      toggle?.setAttribute('aria-expanded', String(open));
      if (overlay) overlay.style.pointerEvents = open ? 'auto' : 'none';
      if (backdrop) backdrop.style.opacity = open ? '1' : '0';
      if (nav) nav.style.transform = open ? 'translateX(0)' : 'translateX(-100%)';
      if (top) top.style.transform = open ? 'rotate(45deg)' : 'translateY(-4px)';
      if (mid) mid.style.opacity = open ? '0' : '1';
      if (bot) bot.style.transform = open ? 'rotate(-45deg)' : 'translateY(4px)';
    }

    toggle?.addEventListener('click', () => setMenu(!open));
    backdrop?.addEventListener('click', () => setMenu(false));

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMenu(false));
    });
  });
</script>
