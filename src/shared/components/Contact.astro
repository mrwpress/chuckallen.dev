---
import type { SiteConfig } from '../utils/config';

interface Props {
  site: SiteConfig;
  title?: string;
  subtitle?: string;
}

const {
  site,
  title = "Let's Build Something Together",
  subtitle = 'Choose the way that works best for you to get started.',
} = Astro.props;

const contactOptions = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z"/></svg>`,
    label: 'Call',
    value: site.phoneFormatted,
    href: `tel:${site.phone}`,
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>`,
    label: 'Email',
    value: site.email,
    href: `mailto:${site.email}`,
  },
  ...(site.calendly ? [{
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>`,
    label: 'Book Now',
    value: 'Schedule a call',
    href: site.calendly,
  }] : []),
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/></svg>`,
    label: 'Message',
    value: 'Send me a message',
    href: '#chat',
  },
];

const turnstileSiteKey = site.turnstileSiteKey;
---

<section id="contact" class="contact-section">
  <div class="section-container">
    <!-- Heading -->
    <div class="contact-heading">
      <h2 class="contact-title">{title}</h2>
      <p class="contact-subtitle">{subtitle}</p>
    </div>

    <!-- Contact option cards -->
    <div class="contact-grid">
      {contactOptions.map((option) => (
        <a
          href={option.href}
          class="contact-card card"
          aria-label={`${option.label}: ${option.value}`}
        >
          <div class="contact-card-icon" aria-hidden="true">
            <Fragment set:html={option.icon} />
          </div>
          <div>
            <div class="contact-card-label">{option.label}</div>
            <div class="contact-card-value">{option.value}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Primary CTA -->
    {site.calendly && (
      <div class="contact-cta">
        <a href={site.calendly} target="_blank" rel="noopener noreferrer" class="btn-primary contact-cta-btn">
          Let's Connect
        </a>
      </div>
    )}
  </div>

  <!-- Chat Modal -->
  <div id="chat-modal-backdrop" class="chat-backdrop" style="display:none">
    <div class="chat-modal">
      <!-- Header -->
      <div class="chat-header">
        <div class="chat-header-info">
          <div class="chat-avatar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/></svg>
          </div>
          <div>
            <div class="chat-name">{site.name}</div>
            <span class="chat-status">We'll respond within a few hours</span>
          </div>
        </div>
        <button id="chat-modal-close" class="chat-close" aria-label="Close chat">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Chat body -->
      <div class="chat-body">
        <div class="chat-bubble-row">
          <div class="chat-bubble-avatar">{site.name.charAt(0)}</div>
          <div class="chat-bubble">
            Hey there! Drop your message and email below and we'll get back to you — usually within a few hours.
          </div>
        </div>

        <form id="chat-form" class="chat-form">
          <label for="chat-email" class="sr-only">Your email</label>
          <input
            type="email"
            id="chat-email"
            name="email"
            required
            placeholder="Your email"
            class="chat-input"
          />
          <label for="chat-message" class="sr-only">Your message</label>
          <textarea
            id="chat-message"
            name="message"
            required
            rows="3"
            placeholder="Type your message..."
            class="chat-input chat-textarea"
          ></textarea>
          {turnstileSiteKey && (
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark" data-size="flexible"></div>
          )}
          <button type="submit" class="chat-submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Section ── */
  .contact-section {
    position: relative;
    padding: 64px 0;
    overflow: hidden;
    background: var(--color-bg);
  }
  @media (min-width: 768px) {
    .contact-section {
      padding: 96px 0;
    }
  }

  .contact-heading {
    text-align: center;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    .contact-heading {
      margin-bottom: 64px;
    }
  }

  .contact-title {
    font-size: 30px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
  }
  @media (min-width: 768px) {
    .contact-title { font-size: 36px; }
  }
  @media (min-width: 1024px) {
    .contact-title { font-size: 48px; }
  }

  .contact-subtitle {
    color: var(--color-text-muted);
    font-size: 16px;
    max-width: 772px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .contact-subtitle { font-size: 18px; }
  }

  /* ── Cards Grid ── */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }

  .contact-card {
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .contact-card {
      padding: 24px;
      gap: 16px;
    }
  }
  .contact-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .contact-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }
  @media (min-width: 768px) {
    .contact-card-icon {
      width: 48px;
      height: 48px;
    }
  }

  .contact-card-label {
    color: var(--color-text);
    font-weight: 600;
    font-size: 18px;
    margin-bottom: 4px;
  }
  @media (min-width: 768px) {
    .contact-card-label { font-size: 20px; }
  }

  .contact-card-value {
    color: var(--color-text-muted);
    font-size: 12px;
  }
  @media (min-width: 768px) {
    .contact-card-value { font-size: 14px; }
  }

  /* ── CTA ── */
  .contact-cta {
    display: flex;
    justify-content: center;
  }

  .contact-cta-btn {
    font-size: 16px;
    padding: 16px 40px;
    width: 100%;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .contact-cta-btn {
      width: auto;
    }
  }

  /* ── Chat Modal ── */
  .chat-backdrop {
    position: fixed;
    inset: 0;
    z-index: 50;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 16px;
    margin: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    border: none;
  }
  @media (min-width: 640px) {
    .chat-backdrop {
      padding: 24px;
    }
  }

  .chat-modal {
    width: 100%;
    max-width: 380px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    margin-left: auto;
    margin-top: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: var(--color-accent);
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
  }

  .chat-name {
    color: var(--color-text);
    font-weight: 600;
    font-size: 14px;
  }

  .chat-status {
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
  }

  .chat-close {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .chat-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .chat-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .chat-bubble-row {
    display: flex;
    gap: 10px;
  }

  .chat-bubble-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-text);
    background: var(--color-accent);
  }

  .chat-bubble {
    border-radius: 16px;
    border-top-left-radius: 4px;
    padding: 10px 16px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    background: rgba(255, 255, 255, 0.06);
  }

  .chat-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .chat-input {
    width: 100%;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 14px;
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    outline: none;
    transition: border-color 0.2s ease;
  }
  .chat-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .chat-input:focus {
    border-color: var(--color-accent);
  }

  .chat-textarea {
    resize: none;
  }

  .chat-submit {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    color: var(--color-text);
    font-weight: 600;
    font-size: 14px;
    background: var(--color-accent);
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .chat-submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const chatLink = document.querySelector('a[href="#chat"]');
    const backdrop = document.getElementById('chat-modal-backdrop') as HTMLElement;
    const closeBtn = document.getElementById('chat-modal-close');
    const form = document.getElementById('chat-form') as HTMLFormElement;

    let turnstileLoaded = false;
    function loadTurnstile() {
      if (turnstileLoaded) return;
      turnstileLoaded = true;
      const s = document.createElement('script');
      s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      s.async = true;
      document.head.appendChild(s);
    }

    function openChat(e: Event) {
      e.preventDefault();
      loadTurnstile();
      if (backdrop) backdrop.style.display = 'flex';
    }

    function closeChat() {
      if (backdrop) backdrop.style.display = 'none';
    }

    chatLink?.addEventListener('click', openChat);
    closeBtn?.addEventListener('click', closeChat);

    backdrop?.addEventListener('click', (e) => {
      if (e.target === backdrop) closeChat();
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = data.get('email') as string;
      const message = data.get('message') as string;
      const token = data.get('cf-turnstile-response') as string;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!token) {
        const existing = form.querySelector('.form-error');
        if (existing) existing.remove();
        const errEl = document.createElement('p');
        errEl.className = 'form-error';
        errEl.style.cssText = 'color: #f87171; font-size: 12px; text-align: center;';
        errEl.textContent = 'Please complete the verification.';
        form.appendChild(errEl);
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, message, source: 'chat', token }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => null);
          throw new Error(err?.error || 'Something went wrong.');
        }

        const body = form.parentElement;
        if (body) {
          form.remove();
          const confirm = document.createElement('div');
          confirm.style.cssText = 'display:flex;gap:10px;';
          const avatar = document.createElement('div');
          avatar.style.cssText = 'width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;background:var(--color-accent);';
          avatar.textContent = document.querySelector('.chat-name')?.textContent?.charAt(0) ?? 'C';
          const bubble = document.createElement('div');
          bubble.style.cssText = 'border-radius:16px;border-top-left-radius:4px;padding:10px 16px;font-size:14px;color:rgba(255,255,255,0.9);line-height:1.6;background:rgba(255,255,255,0.06);';
          bubble.textContent = `Thanks! We got your message and will reach out to ${email} shortly.`;
          confirm.appendChild(avatar);
          confirm.appendChild(bubble);
          body.appendChild(confirm);
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
        const existing = form.querySelector('.form-error');
        if (existing) existing.remove();
        const errEl = document.createElement('p');
        errEl.className = 'form-error';
        errEl.style.cssText = 'color: #f87171; font-size: 12px; text-align: center;';
        errEl.textContent = err instanceof Error ? err.message : 'Failed to send. Please try again.';
        form.appendChild(errEl);
      }
    });
  });
</script>
