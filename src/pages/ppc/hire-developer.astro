---
import Layout from '../../layouts/Layout.astro';
import GridBackground from '../../shared/components/GridBackground.astro';
import BadgeWheel from '../../shared/components/BadgeWheel.astro';
import Contact from '../../shared/components/Contact.astro';
import { site } from '../../config/site';
import { yearsExperience } from '../../shared/utils/config';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'Post-Launch Support', icon: '/images/badge-security.svg' },
  { label: 'Astro', icon: '/images/badge-performance.svg' },
  { label: 'Next.js', icon: '/images/badge-react.svg' },
  { label: 'Clean Code', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Vue & React', icon: '/images/badge-react.svg' },
  { label: 'US Business Hours', icon: '/images/badge-dataviz.svg' },
];
---

<Layout
  title="Hire a Senior Web Developer — Chuck Allen"
  description={`${years}+ years building web applications. No ghosting, no handoffs. A senior developer who communicates, delivers, and stays after launch.`}
  noindex={true}
>
  <!-- Hero -->
  <section class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <p class="hero-eyebrow">Freelance Senior Web Developer</p>
          <h1 class="hero-title">Your project deserves<br /><span class="hero-accent">better.</span></h1>
          <p class="hero-sub">
            You shouldn't have to wonder if your developer will show up tomorrow.
            Or whether the code they wrote last month will hold up next quarter.
          </p>
          <ul class="hero-points">
            <li><span class="hero-icon" aria-hidden="true">👻</span>No ghosting, ever</li>
            <li><span class="hero-icon" aria-hidden="true">🪨</span>{years}+ years of experience</li>
            <li><span class="hero-icon" aria-hidden="true">🤝</span>One developer, one contact</li>
            <li><span class="hero-icon" aria-hidden="true">🛡️</span>Post-launch support included</li>
            <li><span class="hero-icon" aria-hidden="true">⚡</span>Performance-first builds</li>
            <li><span class="hero-icon" aria-hidden="true">🇺🇸</span>US business hours</li>
          </ul>
          <div class="hero-actions">
            <a href={site.calendly} target="_blank" rel="noopener" class="btn-primary">Book a Free Strategy Call</a>
            <a href="#what-you-get" class="btn-outline">See What You Get</a>
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- Pain Points -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">Tired of This?</h2>
      <p class="section-subtitle">
        You've been through it before. These are the reasons most people start looking for a new developer.
      </p>
      <div class="pain-grid">
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">👻</span> The developer who disappeared</h3>
          <p class="pain-desc">Mid-project. No warning. Now you're scrambling to find someone who can pick up their mess.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🔥</span> Code that breaks constantly</h3>
          <p class="pain-desc">Every update introduces new bugs. Every fix creates two more problems. The codebase is held together with duct tape.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🕳️</span> Radio silence on updates</h3>
          <p class="pain-desc">You send a message Monday. Maybe you hear back Thursday. Maybe you don't. You have no idea where your project stands.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">💸</span> Scope creep and surprise bills</h3>
          <p class="pain-desc">The estimate was $5K. The invoice was $12K. Nobody told you about the "unforeseen complexities" until it was too late.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🚪</span> Launched and abandoned</h3>
          <p class="pain-desc">The site went live. The developer moved on. Now something's broken and you can't reach anyone.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🤷</span> Junior devs in a senior role</h3>
          <p class="pain-desc">You hired "senior" and got someone Googling the basics. Architecture decisions that seemed fine now cost you months to undo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section id="what-you-get" class="section">
    <GridBackground blobColor="rgba(220,38,38,0.04)" />
    <div class="section-container">
      <h2 class="section-title">What You Get Instead</h2>
      <p class="section-subtitle">
        What if the next developer you hired actually followed through?
      </p>
      <div class="value-grid">
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> One developer. One point of contact.</h3>
          <p class="value-desc">You talk to the person writing the code. No account managers, no layers, no game of telephone.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Clear, consistent communication</h3>
          <p class="value-desc">Regular updates on progress, blockers, and next steps. Calls, screen shares, Slack — whatever works for your team.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Post-launch support included</h3>
          <p class="value-desc">Your project doesn't end at launch. Bugs get fixed. Questions get answered. You're never left holding the bag.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Clean, documented code</h3>
          <p class="value-desc">Your codebase should make sense to anyone who opens it. Tested, documented, and maintainable — no matter who works on it next.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Performance as a requirement</h3>
          <p class="value-desc">Your site should be fast because it was built that way — not patched after the fact. Astro, Next.js, Vue, React — the right tool for the job.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> US business hours, always</h3>
          <p class="value-desc">Based in Colorado. Available during your work day. No timezone headaches, no 48-hour response delays.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">What the Work Looks Like</h2>
      <div class="results-grid">
        <div class="result-item card">
          <span class="result-number">4.2s → 0.8s</span>
          <p class="result-label">Page load time after migrating a legacy WordPress site to a modern framework</p>
        </div>
        <div class="result-item card">
          <span class="result-number">12 hrs/week</span>
          <p class="result-label">Saved by automating a manual reporting workflow for a 50-person operations team</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Real-time</span>
          <p class="result-label">Custom dashboards replacing spreadsheet-based tracking for logistics and fulfillment</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Zero downtime</span>
          <p class="result-label">Serverless architecture handling 10x traffic spikes without manual intervention</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">No long procurement process. No 40-page proposals. Just a conversation to see if we're a fit.</p>
      <div class="steps-row">
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">1</span> Free strategy call</h3>
          <p class="step-desc">30 minutes. Tell me what you're building, what's broken, or where you're stuck. I'll tell you how I'd approach it.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">2</span> Scope and plan</h3>
          <p class="step-desc">You get a clear plan with milestones, timeline, and cost — no surprises, no hidden fees.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">3</span> Build and ship</h3>
          <p class="step-desc">Your project gets built, you stay updated along the way, and support continues after launch to make sure everything holds up.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    site={site}
    title="Ready for a Developer Who Actually Follows Through?"
    subtitle="Book a free 30-minute call. No pitch, no pressure — just a conversation about your project."
  />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 7rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero { padding: 11.25rem 0 2rem; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 3.75rem;
    }
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile { display: none; }
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 3rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-accent {
    color: var(--color-accent-light);
  }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    max-width: 560px;
  }
  @media (min-width: 768px) {
    .hero-sub { font-size: 1.125rem; }
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-points { gap: 1rem 2.5rem; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-points { grid-template-columns: repeat(3, 1fr); }
  }

  .hero-points li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  @media (min-width: 768px) {
    .hero-points li { font-size: 1.125rem; }
  }

  .hero-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section { padding: 4.5rem 0; }
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 3rem; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .section-subtitle {
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Pain Grid (inline icon + title) ── */
  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .pain-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .pain-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .pain-card { padding: 1.5rem; }
  }
  .pain-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .pain-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .pain-header { font-size: 1.125rem; }
  }

  .pain-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .pain-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .pain-desc { font-size: 0.875rem; }
  }

  /* ── Value Grid (checkmark + title inline) ── */
  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .value-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .value-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .value-card { padding: 1.5rem; }
  }
  .value-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .value-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .value-header { font-size: 1.125rem; }
  }

  .value-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .value-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.125rem;
  }
  @media (min-width: 768px) {
    .value-desc { font-size: 0.875rem; }
  }

  /* ── Results Grid ── */
  .results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .result-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .result-item { padding: 1.5rem; }
  }
  .result-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .result-number {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .result-number { font-size: 1.75rem; }
  }

  .result-label {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .result-label { font-size: 0.875rem; }
  }

  /* ── Steps (inline number + title) ── */
  .steps-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .steps-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .step-card {
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }
  .step-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .step-header { font-size: 1.125rem; }
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-weight: 700;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .step-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.5rem;
  }
  @media (min-width: 768px) {
    .step-desc { font-size: 0.875rem; }
  }
</style>
