---
import Layout from '../../layouts/Layout.astro';
import GridBackground from '../../shared/components/GridBackground.astro';
import BadgeWheel from '../../shared/components/BadgeWheel.astro';
import Contact from '../../shared/components/Contact.astro';
import MockDashboard from '../../components/visuals/MockDashboard.astro';
import TechMarquee from '../../components/visuals/TechMarquee.astro';
import { site } from '../../config/site';
import { yearsExperience } from '../../shared/utils/config';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'Post-Launch Support', icon: '/images/badge-security.svg' },
  { label: 'Astro', icon: '/images/badge-performance.svg' },
  { label: 'Next.js', icon: '/images/badge-react.svg' },
  { label: 'Clean Code', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Vue & React', icon: '/images/badge-react.svg' },
  { label: 'US Business Hours', icon: '/images/badge-dataviz.svg' },
];
---

<Layout
  title="Hire a Freelance Web Developer — Chuck Allen"
  description={`Freelance web developer with ${years}+ years of experience. No ghosting, no handoffs. One developer, one point of contact — from kickoff through post-launch support.`}
  noindex={true}
>
  <!-- Hero -->
  <section class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <p class="hero-eyebrow">Freelance Senior Web Developer for Hire</p>
          <h1 class="hero-title">Your project deserves<br /><span class="hero-accent">a better developer.</span></h1>
          <p class="hero-sub">
            You shouldn't have to chase your developer for updates. You shouldn't have to
            wonder whether the code they shipped will survive next quarter. And you definitely
            shouldn't have to start over because someone disappeared mid-project.
            You need:
          </p>
          <ul class="hero-points">
            <li><span class="hero-icon" aria-hidden="true">👻</span>A developer that doesn't ghost</li>
            <li><span class="hero-icon" aria-hidden="true">🪨</span>{years}+ years, senior-level</li>
            <li><span class="hero-icon" aria-hidden="true">🤝</span>One developer, one contact</li>
            <li><span class="hero-icon" aria-hidden="true">🚀</span>Post-launch support</li>
            <li><span class="hero-icon" aria-hidden="true">⚡</span>Performance-first architecture</li>
            <li><span class="hero-icon" aria-hidden="true">🇺🇸</span>US-based, US business hours</li>
          </ul>
          <div class="hero-actions">
            <a href={site.calendly} target="_blank" rel="noopener" class="btn-primary">Book a Free Strategy Call</a>
            <a href="#what-you-get" class="btn-outline">See What You Get</a>
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- Pain Points -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">Does Any of This Sound Familiar?</h2>
      <p class="section-subtitle">
        You're not wrong for being cautious. If you've hired a freelance web developer before and it went sideways, you already know what's at stake.
      </p>
      <div class="pain-grid">
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">💨</span> You hired someone who vanished</h3>
          <p class="pain-desc">One week they're responsive. The next, silence. You're left scrambling to find someone who can untangle what they left behind — and you're paying twice for the same work. You deserve better than that.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🔥</span> Your codebase is falling apart</h3>
          <p class="pain-desc">Every update breaks something new. Every fix creates two more problems. You shouldn't have to hold your breath every time a change goes live. You deserve code that works — and keeps working.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">📭</span> You're always chasing updates</h3>
          <p class="pain-desc">You send a message Monday. Thursday, still nothing. You shouldn't have to hunt someone down to find out where your own project stands. You are right to expect consistent communication.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">💸</span> The budget kept growing</h3>
          <p class="pain-desc">The estimate said $5K. The invoice said $12K. You are right to expect a clear scope and honest pricing — not "unforeseen complexities" that show up on the bill after the work is done.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🚪</span> You got launched, then abandoned</h3>
          <p class="pain-desc">Your site went live and your developer moved on. Now something's broken and there's nobody to call. You should never have to worry about what happens after launch.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🤷</span> You paid for senior, got junior</h3>
          <p class="pain-desc">You hired "senior-level" and got someone Googling the basics. You are right to expect real architecture decisions from the person you're paying senior rates to — not guesswork that costs you months to undo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section id="what-you-get" class="section">
    <GridBackground blobColor="rgba(220,38,38,0.04)" />
    <div class="section-container">
      <h2 class="section-title">What You Deserve Instead</h2>
      <p class="section-subtitle">
        What if the next freelance developer you hired actually followed through? What if hiring a web developer didn't have to feel like a gamble?
      </p>
      <div class="value-grid">
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> You talk to the person writing the code</h3>
          <p class="value-desc">No account managers, no layers, no game of telephone. You deserve a single point of contact who knows your project inside and out.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> You get updates without asking</h3>
          <p class="value-desc">Regular updates on progress, blockers, and next steps — before you have to chase them. Calls, screen shares, Slack, whatever works for your team.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Your project doesn't end at launch</h3>
          <p class="value-desc">You deserve post-launch support that actually exists. Bugs get fixed. Questions get answered. You should never be left holding the bag after go-live.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Your codebase makes sense</h3>
          <p class="value-desc">You deserve clean, documented code that any developer can pick up — not a tangled mess that locks you into one person. Tested, maintainable, built to last.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> Your site is fast from day one</h3>
          <p class="value-desc">You should expect performance as a baseline, not an afterthought. Astro, Next.js, Vue, React — the right tool for your project, not just the one someone already knows.</p>
        </div>
        <div class="value-card card">
          <h3 class="value-header"><span class="value-check" aria-hidden="true">&#10003;</span> You work on your schedule</h3>
          <p class="value-desc">You deserve a developer who's available during your business day. Colorado-based, US hours — no timezone roulette, no 48-hour response gaps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Demo -->
  <section class="section">
    <div class="section-container">
      <div class="visual-row">
        <div class="visual-panel">
          <MockDashboard variant="project" />
        </div>
        <div class="visual-text">
          <h2 class="section-title">This Is How Your Project Runs</h2>
          <p class="section-subtitle" style="margin-bottom:1rem;">
            Clear milestones. Consistent commits. Response times measured in hours, not days. You always know exactly where your project stands.
          </p>
          <p class="section-subtitle">
            No chasing. No surprises. The kind of transparency you should expect from every developer you hire.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section tech-stack-section">
    <div class="section-container tech-stack-container">
      <h2 class="section-title tech-stack-title">Tools in My Toolbox</h2>
      <p class="section-subtitle tech-stack-sub">The frameworks, platforms, and services I build with every day.</p>
      <TechMarquee />
    </div>
  </section>

  <!-- Results -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">What Your Results Could Look Like</h2>
      <div class="results-grid">
        <div class="result-item card">
          <span class="result-number">4.2s → 0.8s</span>
          <p class="result-label">Your users shouldn't wait. A legacy WordPress migration cut page load by 80% — because performance was designed in, not bolted on.</p>
        </div>
        <div class="result-item card">
          <span class="result-number">12 hrs/week</span>
          <p class="result-label">Your team's time matters. Automating one manual reporting workflow gave a 50-person operations team their Mondays back.</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Real-time</span>
          <p class="result-label">You deserve data you can act on now. Custom dashboards replaced spreadsheet-based tracking for logistics and fulfillment teams.</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Zero downtime</span>
          <p class="result-label">Your site should handle the traffic you worked hard to earn. Serverless architecture handling 10x spikes without anyone scrambling.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">You shouldn't need a procurement process to hire a freelance web developer. Three steps, no gatekeeping.</p>
      <div class="steps-row">
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">1</span> Tell me what you need</h3>
          <p class="step-desc">30-minute call. You walk me through what you're building, what's broken, or where you're stuck. You'll get an honest assessment — not a sales pitch.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">2</span> You get a clear plan</h3>
          <p class="step-desc">Milestones, timeline, and cost — all upfront. You deserve to know exactly what you're paying for before any work starts. No surprises, no hidden fees.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">3</span> Your project ships</h3>
          <p class="step-desc">You stay updated throughout the build. Your project launches on schedule. And support continues afterward — because you shouldn't have to worry about what comes next.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    site={site}
    title="You Deserve a Developer Who Actually Follows Through"
    subtitle="Book a free 30-minute call. You've earned the right to be picky about who touches your code — let's see if this is the right fit."
  />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 7rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero { padding: 11.25rem 0 2rem; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 3.75rem;
    }
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile { display: none; }
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 3rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-accent {
    color: var(--color-accent-light);
  }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    max-width: 560px;
  }
  @media (min-width: 768px) {
    .hero-sub { font-size: 1.125rem; }
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-points { gap: 1rem 2.5rem; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-points { grid-template-columns: repeat(3, 1fr); }
  }

  .hero-points li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  @media (min-width: 768px) {
    .hero-points li { font-size: 1.125rem; }
  }

  .hero-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section { padding: 4.5rem 0; }
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 3rem; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .section-subtitle {
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Pain Grid (inline icon + title) ── */
  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .pain-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .pain-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .pain-card { padding: 1.5rem; }
  }
  .pain-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .pain-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .pain-header { font-size: 1.125rem; }
  }

  .pain-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .pain-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .pain-desc { font-size: 0.875rem; }
  }

  /* ── Value Grid (checkmark + title inline) ── */
  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .value-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .value-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .value-card { padding: 1.5rem; }
  }
  .value-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .value-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .value-header { font-size: 1.125rem; }
  }

  .value-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .value-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.125rem;
  }
  @media (min-width: 768px) {
    .value-desc { font-size: 0.875rem; }
  }

  /* ── Tech Stack ── */
  .tech-stack-container {
    text-align: center;
  }

  .tech-stack-title {
    margin-bottom: 0.25rem;
  }

  .tech-stack-sub {
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Visual Demo ── */
  .visual-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .visual-row {
      flex-direction: row;
      gap: 3.75rem;
      align-items: center;
    }
  }

  .visual-panel {
    width: 100%;
    max-width: 400px;
  }
  @media (min-width: 768px) {
    .visual-panel { max-width: 500px; }
  }
  @media (min-width: 1024px) {
    .visual-panel { flex: 1.2; max-width: none; }
  }

  .visual-text {
    flex: 1;
    min-width: 0;
  }

  /* ── Results Grid ── */
  .results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .result-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .result-item { padding: 1.5rem; }
  }
  .result-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .result-number {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .result-number { font-size: 1.75rem; }
  }

  .result-label {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .result-label { font-size: 0.875rem; }
  }

  /* ── Steps (inline number + title) ── */
  .steps-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .steps-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .step-card {
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }
  .step-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .step-header { font-size: 1.125rem; }
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-weight: 700;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .step-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.5rem;
  }
  @media (min-width: 768px) {
    .step-desc { font-size: 0.875rem; }
  }
</style>
