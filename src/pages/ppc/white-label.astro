---
import Layout from '../../layouts/Layout.astro';
import GridBackground from '../../shared/components/GridBackground.astro';
import BadgeWheel from '../../shared/components/BadgeWheel.astro';
import Contact from '../../shared/components/Contact.astro';
import MockDashboard from '../../components/visuals/MockDashboard.astro';
import { site } from '../../config/site';
import { yearsExperience } from '../../shared/utils/config';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'White-Label Ready', icon: '/images/badge-security.svg' },
  { label: 'Astro', icon: '/images/badge-performance.svg' },
  { label: 'Next.js', icon: '/images/badge-react.svg' },
  { label: 'Overflow Support', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Vue & React', icon: '/images/badge-react.svg' },
  { label: 'US Business Hours', icon: '/images/badge-dataviz.svg' },
];
---

<Layout
  title="White-Label Web Development Partner — Chuck Allen"
  description={`White-label web development for agencies. ${years}+ years building under your brand. US-based, reliable, no client-facing headaches.`}
  noindex={true}
>
  <!-- Hero -->
  <section class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <p class="hero-eyebrow">White-Label Web Development Partner</p>
          <h1 class="hero-title">Your agency deserves<br /><span class="hero-accent">a better bench.</span></h1>
          <p class="hero-sub">
            You shouldn't have to turn down good work because your team is at capacity.
            You shouldn't have to gamble on offshore developers who can't meet your standards.
            You deserve a senior web developer who works under your brand, on your timeline,
            invisible to your clients — with {years}+ years of experience and none of the overhead.
          </p>
          <ul class="hero-points">
            <li><span class="hero-icon" aria-hidden="true">🏢</span>White-label web development</li>
            <li><span class="hero-icon" aria-hidden="true">🤝</span>Your brand, every deliverable</li>
            <li><span class="hero-icon" aria-hidden="true">⏰</span>US-based, US business hours</li>
            <li><span class="hero-icon" aria-hidden="true">🔒</span>Your clients stay yours</li>
            <li><span class="hero-icon" aria-hidden="true">📋</span>Clean code, clean handoffs</li>
            <li><span class="hero-icon" aria-hidden="true">💰</span>No full-time salary overhead</li>
          </ul>
          <div class="hero-actions">
            <a href={site.calendly} target="_blank" rel="noopener" class="btn-primary">Book a Free Strategy Call</a>
            <a href="#how-it-works" class="btn-outline">See How It Works</a>
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- The Problem -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">Any of This Keeping You Up?</h2>
      <p class="section-subtitle">
        You built your agency to grow — not to spend your nights worrying about capacity, quality, and whether your outsource partner will come through this time.
      </p>
      <div class="pain-grid">
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">📈</span> You're turning down good work</h3>
          <p class="pain-desc">Your developers are maxed out. You're pushing timelines or saying no to projects you should be winning. You shouldn't have to choose between growth and quality — you deserve both.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🌏</span> Outsourcing overseas burned you</h3>
          <p class="pain-desc">The timezone gaps. The miscommunication. The code you had to rewrite anyway. You are right to want a US-based web development partner who actually understands your standards.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🎭</span> Your last freelancer went rogue</h3>
          <p class="pain-desc">They missed the deadline. They contacted your client directly. They delivered code your team can't maintain. You deserve a partner who stays invisible and stays reliable.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">💰</span> You're paying full-time for part-time needs</h3>
          <p class="pain-desc">You don't need a senior developer 40 hours a week. You need one when a project demands it. You shouldn't have to carry the salary, benefits, and bench time just to have capacity when it matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="section">
    <GridBackground blobColor="rgba(220,38,38,0.04)" />
    <div class="section-container">
      <h2 class="section-title">How Your Partnership Works</h2>
      <p class="section-subtitle">
        You deserve a white-label development process that fits how your agency actually operates — not the other way around.
      </p>
      <div class="steps-row">
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">1</span> You send the project</h3>
          <p class="step-desc">Specs, designs, or just the problem. You get a timeline and cost your team can plan around — because you deserve clarity before any work starts.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">2</span> Your project gets built invisibly</h3>
          <p class="step-desc">Your repos, your conventions, your Slack. Your clients should never know the work was outsourced — and they won't. Clean code, clean handoffs, every time.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">3</span> You deliver and keep the relationship</h3>
          <p class="step-desc">On time, on spec, on budget. Your clients get the quality they're paying for. You keep the margin and the trust you've earned.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Handle -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">What You Should Expect from a White-Label Partner</h2>
      <div class="service-grid">
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Full Stack Web Development</h3>
          <p class="service-desc">You deserve complete builds, not half-finished handoffs. Astro, Next.js, Vue, React — frontend to backend, database to deployment, all under your brand.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Overflow Capacity On Demand</h3>
          <p class="service-desc">Your team is slammed and your clients are waiting. You should be able to scale up without a hiring scramble — the overflow gets handled at your quality standard.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Performance Rescue</h3>
          <p class="service-desc">Your client's site is slow and they're looking at you. You deserve a partner who can audit, optimize, and migrate — Core Web Vitals scores that keep your clients happy.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Integrations & APIs</h3>
          <p class="service-desc">Payment gateways, CRMs, shipping APIs, custom connectors. You should expect robust error handling and monitoring built in — not fragile connections that break on you.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Ongoing Maintenance</h3>
          <p class="service-desc">Your clients deserve ongoing support after launch — and you deserve a reseller partner who handles it. Bug fixes, feature adds, security updates, all under your brand.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-header"><span class="service-check" aria-hidden="true">&#10003;</span> Technical Architecture</h3>
          <p class="service-desc">You shouldn't have to spec complex builds alone. Your project gets a scalable blueprint that won't need a rebuild in six months — then your team or mine builds it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Demo -->
  <section class="section">
    <div class="section-container">
      <div class="visual-row">
        <div class="visual-panel">
          <MockDashboard variant="agency" />
        </div>
        <div class="visual-text">
          <h2 class="section-title">Your Agency's View</h2>
          <p class="section-subtitle" style="margin-bottom:1rem;">
            Every project tracked. Every deadline met. Your clients see your brand — you see the full picture behind the scenes.
          </p>
          <p class="section-subtitle">
            100% on-time delivery across 18 projects. That's the kind of bench strength your agency deserves.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Agencies Choose Me -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">What You Are Right to Expect</h2>
      <div class="trust-grid">
        <div class="trust-item card">
          <span class="trust-stat">{years}+ years</span>
          <p class="trust-desc">You deserve a partner who understands how agencies work — not someone learning on your client's dime. {years}+ years building for agencies, startups, and enterprise teams.</p>
        </div>
        <div class="trust-item card">
          <span class="trust-stat">US hours</span>
          <p class="trust-desc">You shouldn't have to schedule around a 12-hour timezone gap. Colorado-based, available during your business day, every time.</p>
        </div>
        <div class="trust-item card">
          <span class="trust-stat">Zero drama</span>
          <p class="trust-desc">Your clients stay yours. Deadlines get met. Code stays maintainable. You are right to demand no surprises and no rogue behavior from a development partner.</p>
        </div>
        <div class="trust-item card">
          <span class="trust-stat">No contracts required</span>
          <p class="trust-desc">You shouldn't have to lock in before you know the work is good. Start with one project. If the quality speaks for itself, you keep coming back because you want to — not because you have to.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    site={site}
    title="Your Agency Deserves a Partner You Can Count On"
    subtitle="Book a free 30-minute call. You've worked too hard to risk your client relationships on unreliable outsource partners — let's see if this is the right fit."
  />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 7rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero { padding: 11.25rem 0 2rem; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 3.75rem;
    }
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile { display: none; }
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 3rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-accent {
    color: var(--color-accent-light);
  }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    max-width: 560px;
  }
  @media (min-width: 768px) {
    .hero-sub { font-size: 1.125rem; }
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-points { gap: 1rem 2.5rem; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-points { grid-template-columns: repeat(3, 1fr); }
  }

  .hero-points li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  @media (min-width: 768px) {
    .hero-points li { font-size: 1.125rem; }
  }

  .hero-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section { padding: 4.5rem 0; }
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 3rem; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .section-subtitle {
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Pain Grid (inline icon + title) ── */
  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .pain-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .pain-card { padding: 1.5rem; }
  }
  .pain-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .pain-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .pain-header { font-size: 1.125rem; }
  }

  .pain-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .pain-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .pain-desc { font-size: 0.875rem; }
  }

  /* ── Steps (inline number + title) ── */
  .steps-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .steps-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .step-card {
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }
  .step-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .step-header { font-size: 1.125rem; }
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-weight: 700;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .step-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.5rem;
  }
  @media (min-width: 768px) {
    .step-desc { font-size: 0.875rem; }
  }

  /* ── Service Grid (checkmark + title inline) ── */
  .service-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .service-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .service-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .service-card { padding: 1.5rem; }
  }
  .service-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .service-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .service-header { font-size: 1.125rem; }
  }

  .service-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .service-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.125rem;
  }
  @media (min-width: 768px) {
    .service-desc { font-size: 0.875rem; }
  }

  /* ── Visual Demo ── */
  .visual-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .visual-row {
      flex-direction: row;
      gap: 3.75rem;
      align-items: center;
    }
  }

  .visual-panel {
    width: 100%;
    max-width: 400px;
  }
  @media (min-width: 768px) {
    .visual-panel { max-width: 500px; }
  }
  @media (min-width: 1024px) {
    .visual-panel { flex: 1.2; max-width: none; }
  }

  .visual-text {
    flex: 1;
    min-width: 0;
  }

  /* ── Trust Grid ── */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .trust-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .trust-item { padding: 1.5rem; }
  }
  .trust-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .trust-stat {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .trust-stat { font-size: 1.75rem; }
  }

  .trust-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .trust-desc { font-size: 0.875rem; }
  }
</style>
