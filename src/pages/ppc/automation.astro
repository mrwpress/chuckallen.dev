---
import Layout from '../../layouts/Layout.astro';
import GridBackground from '../../shared/components/GridBackground.astro';
import BadgeWheel from '../../shared/components/BadgeWheel.astro';
import Contact from '../../shared/components/Contact.astro';
import MockDashboard from '../../components/visuals/MockDashboard.astro';
import { site } from '../../config/site';
import { yearsExperience } from '../../shared/utils/config';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'Workflow Automation', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Data Visualization', icon: '/images/badge-dataviz.svg' },
  { label: 'Custom Solutions', icon: '/images/badge-performance.svg' },
  { label: 'Error Handling', icon: '/images/badge-security.svg' },
  { label: 'Post-Launch Support', icon: '/images/badge-react.svg' },
  { label: 'US Business Hours', icon: '/images/badge-dataviz.svg' },
];
---

<Layout
  title="Business Workflow Automation Consulting — Chuck Allen"
  description={`Custom workflow automation for small businesses. Eliminate manual processes, save hours every week. ${years}+ years experience. Free strategy call.`}
  noindex={true}
>
  <!-- Hero -->
  <section class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <p class="hero-eyebrow">Business Workflow Automation Consulting</p>
          <h1 class="hero-title">Your team deserves<br /><span class="hero-accent">their time back.</span></h1>
          <p class="hero-sub">
            You shouldn't have to watch your best people copy numbers between spreadsheets.
            You shouldn't have to rebuild the same report every Monday morning. And you definitely
            shouldn't be losing leads because a follow-up fell through the cracks.
            {years}+ years building custom workflow automation for small businesses.
          </p>
          <ul class="hero-points">
            <li><span class="hero-icon" aria-hidden="true">📋</span>Your data entry, automated</li>
            <li><span class="hero-icon" aria-hidden="true">📊</span>Your reports, built for you</li>
            <li><span class="hero-icon" aria-hidden="true">🔗</span>Your systems, finally connected</li>
            <li><span class="hero-icon" aria-hidden="true">🔔</span>Your alerts, where you see them</li>
            <li><span class="hero-icon" aria-hidden="true">🛡️</span>Real error handling built in</li>
            <li><span class="hero-icon" aria-hidden="true">⏱️</span>12+ hours back every week</li>
          </ul>
          <div class="hero-actions">
            <a href={site.calendly} target="_blank" rel="noopener" class="btn-primary">Book a Free Strategy Call</a>
            <a href="#what-gets-automated" class="btn-outline">See What Gets Automated</a>
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- Pain Points -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">Is This Where Your Hours Are Going?</h2>
      <p class="section-subtitle">
        You are right to feel frustrated. These are the business processes that quietly steal hours from small businesses every week — and most people just accept it.
      </p>
      <div class="pain-grid">
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">📋</span> Your team is doing data entry by hand</h3>
          <p class="pain-desc">Someone is copying numbers between systems every single day. You shouldn't have to pay skilled people to do work a machine should handle. Your team's time is worth more than that.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">📊</span> Your reports start from scratch every week</h3>
          <p class="pain-desc">Every Monday, someone pulls data from three tools, pastes it into a spreadsheet, and formats it. You deserve reports that build themselves — because your Monday mornings should be for decisions, not data entry.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🔔</span> Your leads are going cold</h3>
          <p class="pain-desc">Leads slip through because nobody caught them in time. Issues escalate because the alert was buried in an inbox. You should never lose revenue because a follow-up fell through the cracks.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🔗</span> Your systems don't talk to each other</h3>
          <p class="pain-desc">Your CRM doesn't talk to your invoicing. Your invoicing doesn't talk to your project management. You deserve connected business workflows — not a dozen islands with you as the bridge.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🧑‍💻</span> Your best people are wasting their talent</h3>
          <p class="pain-desc">Your most skilled team members are spending 30% of their time on tasks that don't need their expertise. You are right to want that time back — that's expensive talent doing inexpensive work.</p>
        </div>
        <div class="pain-card card">
          <h3 class="pain-header"><span class="pain-icon" aria-hidden="true">🔧</span> Your "automation" keeps breaking</h3>
          <p class="pain-desc">Someone set up a Zapier chain two years ago. It breaks every month. Nobody knows how it works. You deserve automation solutions that actually hold up — not duct tape with a subscription fee.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Gets Automated -->
  <section id="what-gets-automated" class="section">
    <GridBackground blobColor="rgba(220,38,38,0.04)" />
    <div class="section-container">
      <h2 class="section-title">What Your Business Deserves</h2>
      <p class="section-subtitle">
        Every one of these workflows can be automated. You should expect custom automation solutions that fit your business — not the other way around.
      </p>
      <div class="auto-grid">
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your systems, in sync</h3>
          <p class="auto-desc">CRM to invoicing, inventory to storefront, project management to time tracking. You deserve real-time, two-way data sync with error handling — not manual copy-paste between tabs.</p>
        </div>
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your reports, delivered automatically</h3>
          <p class="auto-desc">Daily, weekly, or monthly — generated and delivered without anyone lifting a finger. You should expect dashboards that update themselves, not spreadsheets that need rebuilding.</p>
        </div>
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your leads, followed up instantly</h3>
          <p class="auto-desc">New lead comes in, gets scored, assigned to the right person, and followed up with — all before anyone touches it. You shouldn't lose deals because a response took too long.</p>
        </div>
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your workflows, end to end</h3>
          <p class="auto-desc">Order received → invoice created → team notified → status updated → customer emailed. You deserve multi-step business process automation that runs itself and stays tracked.</p>
        </div>
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your alerts, where you actually see them</h3>
          <p class="auto-desc">Something goes wrong? The right person knows immediately. You should expect alerts on Slack, SMS, or wherever your team actually looks — not buried in an inbox nobody checks.</p>
        </div>
        <div class="auto-card card">
          <h3 class="auto-header"><span class="auto-check" aria-hidden="true">&#10003;</span> Your documents, generated from data</h3>
          <p class="auto-desc">Proposals, invoices, reports, and contracts — created from your data and sent automatically. You deserve consistent formatting every time, not manual templates with copy-paste errors.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Demo -->
  <section class="section">
    <div class="section-container">
      <div class="visual-row">
        <div class="visual-panel">
          <MockDashboard variant="workflow" />
        </div>
        <div class="visual-text">
          <h2 class="section-title">This Is What Running Looks Like</h2>
          <p class="section-subtitle" style="margin-bottom:1rem;">
            Every workflow monitored. Every task tracked. Every error caught before your team even knows about it.
          </p>
          <p class="section-subtitle">
            No more checking five tools to see if things ran. One view, real-time, built around your actual processes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">You Deserve to See the Numbers First</h2>
      <p class="section-subtitle">
        You're right to want proof before investing. These aren't sales claims — they're industry-wide findings from businesses that automated their manual processes.
      </p>
      <div class="roi-grid">
        <div class="roi-item card">
          <span class="roi-stat">30–60%</span>
          <p class="roi-desc">Cost reduction in operations centers that automated repetitive tasks — with higher delivery quality. Your operations budget should be working harder for you. <a href="https://www.mckinsey.com/capabilities/operations/our-insights/operations-management-reshaped-by-robotic-automation" target="_blank" rel="noopener" class="roi-cite">McKinsey</a></p>
        </div>
        <div class="roi-item card">
          <span class="roi-stat">12+ hrs/week</span>
          <p class="roi-desc">Saved by automating a single reporting workflow. Your team shouldn't spend their Mondays on work a machine can do in seconds.</p>
        </div>
        <div class="roi-item card">
          <span class="roi-stat">7x more likely</span>
          <p class="roi-desc">To qualify a lead when response happens within an hour. You shouldn't lose deals because a follow-up took too long. Automated workflows respond in seconds. <a href="https://ainora.lt/blog/lead-response-time-statistics-every-study-2026" target="_blank" rel="noopener" class="roi-cite">HBR Study via AInora</a></p>
        </div>
        <div class="roi-item card">
          <span class="roi-stat">30–90 days</span>
          <p class="roi-desc">Typical payback period for business process automation consulting engagements. You deserve automation that pays for itself within the first quarter — and most do.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="section-container">
      <h2 class="section-title">How Your Automation Gets Built</h2>
      <p class="section-subtitle">
        You shouldn't have to reshape your business around someone else's platform. Your workflow automation gets built around how you actually operate.
      </p>
      <div class="steps-row">
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">1</span> You show me what's eating your time</h3>
          <p class="step-desc">Free strategy call. Walk me through the processes draining your team. You deserve to know exactly what can be automated and how many hours you'll get back — before committing to anything.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">2</span> Your automation gets built right</h3>
          <p class="step-desc">Custom automation with real error handling and monitoring — not a fragile chain that breaks silently. You should see it work before it goes live, and you will.</p>
        </div>
        <div class="step-card card">
          <h3 class="step-header"><span class="step-num">3</span> You get support that lasts</h3>
          <p class="step-desc">It goes live, your team gets trained, and support continues as your needs evolve. You should never worry about what happens when something needs adjusting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Not Off-the-Shelf -->
  <section class="section">
    <div class="section-container">
      <div class="diff-row">
        <div class="diff-content">
          <h2 class="section-title">You Deserve Better Than Off-the-Shelf</h2>
          <p class="diff-text">
            You shouldn't have to force your business into someone else's template. Off-the-shelf automation
            platforms work great — until you hit their limits. Then you're stuck. You can't customize the logic,
            you can't handle your edge cases, and you're paying monthly for something that doesn't quite fit.
          </p>
          <p class="diff-text">
            You are right to want automation that fits your business — not the other way around. Custom workflow automation
            means no monthly platform fees, no feature limitations, and no vendor lock-in. You own it, completely.
          </p>
          <p class="diff-text diff-highlight">
            {years}+ years building custom automation solutions for small businesses. US-based. Post-launch support included.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    site={site}
    title="Your Team Deserves Their Time Back"
    subtitle="Book a free 30-minute call. You've been watching your team waste hours on work that should run itself — let's figure out what it would take to fix that."
  />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 7rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero { padding: 11.25rem 0 2rem; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 3.75rem;
    }
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile { display: none; }
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 3rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-accent {
    color: var(--color-accent-light);
  }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    max-width: 560px;
  }
  @media (min-width: 768px) {
    .hero-sub { font-size: 1.125rem; }
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-points { gap: 1rem 2.5rem; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-points { grid-template-columns: repeat(3, 1fr); }
  }

  .hero-points li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  @media (min-width: 768px) {
    .hero-points li { font-size: 1.125rem; }
  }

  .hero-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section { padding: 4.5rem 0; }
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 3rem; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .section-subtitle {
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Pain Grid (inline icon + title) ── */
  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .pain-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .pain-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .pain-card { padding: 1.5rem; }
  }
  .pain-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .pain-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .pain-header { font-size: 1.125rem; }
  }

  .pain-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .pain-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .pain-desc { font-size: 0.875rem; }
  }

  /* ── Automation Grid (checkmark + title inline) ── */
  .auto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .auto-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .auto-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .auto-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .auto-card { padding: 1.5rem; }
  }
  .auto-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .auto-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .auto-header { font-size: 1.125rem; }
  }

  .auto-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .auto-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.125rem;
  }
  @media (min-width: 768px) {
    .auto-desc { font-size: 0.875rem; }
  }

  /* ── ROI Grid ── */
  .roi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .roi-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .roi-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .roi-item { padding: 1.5rem; }
  }
  .roi-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .roi-stat {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .roi-stat { font-size: 2rem; }
  }

  .roi-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .roi-desc { font-size: 0.875rem; }
  }

  .roi-cite {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  .roi-cite:hover {
    opacity: 1;
    color: var(--color-accent-light);
  }

  /* ── Steps (inline number + title) ── */
  .steps-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .steps-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .step-card {
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }
  .step-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .step-header { font-size: 1.125rem; }
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-dim);
    color: var(--color-accent-light);
    font-weight: 700;
    font-size: 0.8125rem;
    flex-shrink: 0;
  }

  .step-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-left: 2.5rem;
  }
  @media (min-width: 768px) {
    .step-desc { font-size: 0.875rem; }
  }

  /* ── Visual Demo ── */
  .visual-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .visual-row {
      flex-direction: row;
      gap: 3.75rem;
      align-items: center;
    }
  }

  .visual-panel {
    width: 100%;
    max-width: 400px;
  }
  @media (min-width: 768px) {
    .visual-panel { max-width: 500px; }
  }
  @media (min-width: 1024px) {
    .visual-panel { flex: 1.2; max-width: none; }
  }

  .visual-text {
    flex: 1;
    min-width: 0;
  }

  /* ── Differentiator ── */
  .diff-row {
    max-width: 680px;
  }

  .diff-text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
