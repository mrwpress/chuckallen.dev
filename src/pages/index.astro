---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import chuckPhoto from '../assets/images/chuck-allen.png';
import GridBackground from '../shared/components/GridBackground.astro';
import BadgeWheel from '../shared/components/BadgeWheel.astro';
import Contact from '../shared/components/Contact.astro';
import { site } from '../config/site';
import { yearsExperience } from '../shared/utils/config';
import GoogleReviewBadge from '../components/GoogleReviewBadge.astro';
import Testimonials from '../components/Testimonials.astro';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'Astro', icon: '/images/badge-performance.svg' },
  { label: 'Next.js', icon: '/images/badge-react.svg' },
  { label: 'Data Visualization', icon: '/images/badge-dataviz.svg' },
  { label: 'Automation', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Vue & React', icon: '/images/badge-react.svg' },
  { label: 'Serverless Architecture', icon: '/images/badge-security.svg' },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <h1 class="hero-title">Your project deserves</h1>
          <p class="hero-rotating">
            <span class="rotating-word"><span class="rw-text"></span></span>
          </p>
          <ul class="hero-points">
            <li><span class="hero-icon" aria-hidden="true">🪳</span>Clean, bug-free code</li>
            <li><svg class="hero-icon hero-icon-speed" viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="17" stroke="#1e3a1e" stroke-width="3"/><circle cx="20" cy="20" r="17" stroke="#0cce6b" stroke-width="3" stroke-dasharray="106.8" stroke-dashoffset="0" stroke-linecap="round" transform="rotate(-90 20 20)"/><text x="20" y="24" text-anchor="middle" fill="#0cce6b" font-size="13" font-weight="700">100</text></svg>Speed that converts</li>
            <li><span class="hero-icon" aria-hidden="true">🤖</span>Less manual, more automated</li>
            <li><span class="hero-icon" aria-hidden="true">🪨</span>Stability you can count on</li>
            <li><span class="hero-icon" aria-hidden="true">👻</span>A developer who doesn't ghost</li>
            <li><span class="hero-icon" aria-hidden="true">⚙️</span>Architecture that scales</li>
          </ul>
          <p class="hero-closer">{years}+ years solving exactly these problems — and I stick around to make sure they stay solved.</p>
          <div class="hero-actions">
            <a href="/#contact" class="btn-primary">Get Started</a>
            <a href="/#services" class="btn-outline">See How I Help</a>
            <GoogleReviewBadge />
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <!-- Mobile marquee (BadgeWheel hides desktop version internally, but we need a second instance outside the hidden wrapper) -->
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="section-container">
      <div class="about-row">
        <div class="about-photo">
          <Picture
            src={chuckPhoto}
            formats={['avif', 'webp']}
            loading="lazy"
            decoding="async"
            alt="Chuck Allen"
            class="about-img"
          />
        </div>
        <div class="about-content">
          <h2 class="section-title">Hi, I'm Chuck.</h2>
          <p>{years} years building for agencies, startups, and enterprise teams. I've seen what breaks at scale and what survives — you get that instinct from day one.</p>
          <p>I take the time to understand what you're actually trying to accomplish, and I stick with it until it's done. I don't disappear after launch. I don't ghost when things get hard. I'd rather build a real working relationship than chase the next gig.</p>
          <p>I use AI-assisted tooling to move faster without cutting corners — smarter testing, faster prototyping, more thorough reviews. You get senior-level thinking at modern speed.</p>
          <p>Based in Colorado, available during US business hours. Calls, screen shares, Slack — whatever works for your team. White-label friendly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section">
    <div class="section-container">
      <h2 class="section-title">You Know Something's Not Working</h2>
      <p class="section-subtitle">
        Maybe it's the site that takes forever to load. The reports your team builds by hand every week. The integrations that break every time a vendor updates their API. Here's how I fix that.
      </p>
      <div class="services-grid">
        <div class="service-card card">
          <h3 class="service-name">Performance That Pays For Itself</h3>
          <p class="service-desc">Your slow site is costing you customers — every second of delay cuts conversions. I build on Astro, Next.js, Vue, and React with performance as a requirement, not an afterthought.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Integrations That Don't Break</h3>
          <p class="service-desc">Tired of duct-taped API connections that fail silently? I build robust integrations — payment gateways, shipping APIs, CRMs, and custom connectors — with error handling and alerts built in.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Dashboards You'll Actually Use</h3>
          <p class="service-desc">Your data is buried in spreadsheets and nobody's acting on it. I build real-time dashboards that surface what matters — so your team spots problems in minutes, not days.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Automation That Gives You Hours Back</h3>
          <p class="service-desc">Your team shouldn't be doing the same manual work every week. I build workflows, scheduled tasks, and intelligent alerts that eliminate the repetitive stuff and catch issues before your customers do.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Architecture That Scales With You</h3>
          <p class="service-desc">Don't rebuild everything the moment you grow. Serverless, edge functions, Cloudflare Workers — I design systems that handle ten times the traffic without ten times the cost.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">A Developer Who Stays</h3>
          <p class="service-desc">No vanishing acts. No handoff to a junior. I manage your project end-to-end — planning, building, communicating, and supporting it after launch. Your point of contact is the person writing the code.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost of Inaction -->
  <section id="cost" class="section">
    <div class="section-container">
      <h2 class="section-title">Are These Affecting Your Bottom Line?</h2>
      <p class="section-subtitle">
        These aren't hypotheticals. These are the measurable costs businesses pay every day for outdated systems and manual processes.
      </p>
      <div class="cost-grid">
        <div class="cost-item card">
          <span class="cost-stat">1% sales lost</span>
          <p class="cost-desc">For every 100ms a site takes to load. Slow pages don't just frustrate visitors — they cost real revenue before anyone even sees the product. <a href="https://www.conductor.com/academy/page-speed-resources/faq/amazon-page-speed-study/" target="_blank" rel="noopener" class="cost-cite">Amazon Study</a></p>
        </div>
        <div class="cost-item card">
          <span class="cost-stat">30–60%</span>
          <p class="cost-desc">Cost reduction achieved by operations centers that automate manual, repetitive tasks — while also increasing delivery quality. <a href="https://www.mckinsey.com/capabilities/operations/our-insights/operations-management-reshaped-by-robotic-automation" target="_blank" rel="noopener" class="cost-cite">McKinsey</a></p>
        </div>
        <div class="cost-item card">
          <span class="cost-stat">7x more likely</span>
          <p class="cost-desc">To qualify a lead when the response happens within an hour. The average business takes 42 hours. Automated workflows respond in seconds — around the clock. <a href="https://ainora.lt/blog/lead-response-time-statistics-every-study-2026" target="_blank" rel="noopener" class="cost-cite">HBR Study via AInora</a></p>
        </div>
        <div class="cost-item card">
          <span class="cost-stat">$12.9M/year</span>
          <p class="cost-desc">Average annual cost of poor data quality across organizations. Clean data pipelines and real-time dashboards turn that liability into insight. <a href="https://www.dataversity.net/articles/putting-a-number-on-bad-data/" target="_blank" rel="noopener" class="cost-cite">Gartner via Dataversity</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work / Portfolio -->
  <section id="work" class="section">
    <GridBackground blobColor="rgba(0,118,157,0.05)" />
    <div class="section-container">
      <h2 class="section-title">Results, Not Résumé Lines</h2>
      <p class="section-subtitle">
        Full case studies are on the way. In the meantime, here's what the work actually looks like.
      </p>
      <div class="results-grid">
        <div class="result-item card">
          <span class="result-number">4.2s → 0.8s</span>
          <p class="result-label">Page load time after migrating a legacy WordPress site to a modern framework</p>
        </div>
        <div class="result-item card">
          <span class="result-number">12 hrs/week</span>
          <p class="result-label">Saved by automating a manual reporting workflow for a 50-person operations team</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Real-time</span>
          <p class="result-label">Custom dashboards replacing spreadsheet-based tracking for logistics and fulfillment</p>
        </div>
        <div class="result-item card">
          <span class="result-number">Zero downtime</span>
          <p class="result-label">Serverless architecture handling 10x traffic spikes without manual intervention</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Contact -->
  <Contact
    site={site}
    title="Ready to Stop Losing Time to Bad Tooling?"
    subtitle="Tell me what's not working. I'll tell you how to fix it — no pitch, no pressure."
  />
</Layout>

<script>
  const words = [
    "Attention to detail.",
    "Follow through.",
    "Scalable architecture.",
    "Transparent communication.",
    "Modern frameworks.",
    "Post-launch support.",
    "Continuous integration.",
    "Clean, documented code.",
  ];
  const el = document.querySelector(".rotating-word .rw-text");

  if (el) {
    const startAnimation = () => {
      let wordIndex = 0;
      let charIndex = 0;
      let isDeleting = false;

      const typingSpeed = 70;
      const deletingSpeed = 40;
      const pauseAfterTyped = 1000;

      const typeLoop = () => {
        const currentWord = words[wordIndex];

        if (!isDeleting) {
          charIndex++;
          requestAnimationFrame(() => {
            el.textContent = currentWord.slice(0, charIndex);
          });

          if (charIndex === currentWord.length) {
            isDeleting = true;
            setTimeout(typeLoop, pauseAfterTyped);
            return;
          }

          setTimeout(typeLoop, typingSpeed);
        } else {
          charIndex--;
          requestAnimationFrame(() => {
            el.textContent = currentWord.slice(0, charIndex);
          });

          if (charIndex === 0) {
            isDeleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            setTimeout(typeLoop, 150);
            return;
          }

          setTimeout(typeLoop, deletingSpeed);
        }
      };

      el.textContent = "";
      setTimeout(typeLoop, 400);
    };

    if (typeof requestIdleCallback === "function") {
      requestIdleCallback(startAnimation, { timeout: 2000 });
    } else {
      setTimeout(startAnimation, 200);
    }
  }
</script>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 7rem 0 1.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero {
      padding: 11.25rem 0 2rem;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 3.75rem;
    }
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile {
      display: none;
    }
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 3rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 4rem; }
  }

  .hero-rotating {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .hero-rotating { font-size: 1.75rem; }
  }
  @media (min-width: 1024px) {
    .hero-rotating { font-size: 2.25rem; }
  }

  .rotating-word {
    display: inline-block;
    line-height: 1;
    vertical-align: baseline;
  }

  .rw-text {
    display: inline-block;
    color: var(--color-accent-light);
    border-right: 2px solid var(--color-accent-light);
    padding-right: 4px;
    white-space: nowrap;
    animation: hero-cursor-blink 0.8s steps(1, end) infinite;
  }

  @keyframes hero-cursor-blink {
    0%, 49% {
      border-right-color: var(--color-accent-light);
    }
    50%, 100% {
      border-right-color: transparent;
    }
  }

  @media (max-width: 767px) {
    .rotating-word {
      position: relative;
    }

    .rotating-word::before {
      content: "Transparent communication.";
      visibility: hidden;
      white-space: nowrap;
      padding-right: 4px;
    }

    .rw-text {
      position: absolute;
      left: 0;
      top: 0;
    }
  }

  .hero-points {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-points {
      gap: 1rem 2.5rem;
    }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-points {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hero-points li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .hero-icon {
    font-size: 2.25rem;
    flex-shrink: 0;
  }

  .hero-icon-speed {
    width: 2.25rem;
    height: 2.25rem;
  }

  @media (min-width: 768px) {
    .hero-points li { font-size: 1.125rem; }
  }

  .hero-closer {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .hero-closer {
      font-size: 1.125rem;
      margin-bottom: 2.5rem;
    }
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section {
      padding: 4.5rem 0;
    }
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2.25rem; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 3rem; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 600px;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .section-subtitle {
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Services Grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .service-card { padding: 1.5rem; }
  }
  .service-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .service-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .service-name { font-size: 1.125rem; }
  }

  .service-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .service-desc { font-size: 0.875rem; }
  }

  /* ── About ── */
  .about-row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .about-row {
      flex-direction: row;
      gap: 3.75rem;
      align-items: flex-start;
    }
  }

  .about-photo {
    flex-shrink: 0;
    max-width: 100%;
  }

  .about-img {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: 1rem;
    border: 1px solid var(--color-border-light);
  }
  @media (min-width: 768px) {
    .about-img {
      max-width: 360px;
    }
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
    min-width: 0;
  }
  @media (min-width: 768px) {
    .about-content {
      font-size: 1.0625rem;
      gap: 1rem;
    }
  }

  /* ── Cost of Inaction ── */
  .cost-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .cost-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .cost-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .cost-item { padding: 1.5rem; }
  }
  .cost-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .cost-stat {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .cost-stat { font-size: 2rem; }
  }

  .cost-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .cost-desc { font-size: 0.875rem; }
  }

  .cost-cite {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  .cost-cite:hover {
    opacity: 1;
    color: var(--color-accent-light);
  }

  /* ── Results Grid ── */
  .results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .result-item {
    padding: 1.25rem;
    transition: border-color 0.2s ease;
  }
  @media (min-width: 768px) {
    .result-item { padding: 1.5rem; }
  }
  .result-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .result-number {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .result-number { font-size: 1.75rem; }
  }

  .result-label {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  @media (min-width: 768px) {
    .result-label { font-size: 0.875rem; }
  }
</style>
