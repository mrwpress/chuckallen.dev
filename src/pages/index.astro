---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import chuckPhoto from '../assets/images/chuck-allen.png';
import GridBackground from '../shared/components/GridBackground.astro';
import BadgeWheel from '../shared/components/BadgeWheel.astro';
import Contact from '../shared/components/Contact.astro';
import { site } from '../config/site';
import { yearsExperience } from '../shared/utils/config';

const years = yearsExperience(site);

const badgeItems = [
  { label: 'Astro', icon: '/images/badge-performance.svg' },
  { label: 'Next.js', icon: '/images/badge-react.svg' },
  { label: 'Data Visualization', icon: '/images/badge-dataviz.svg' },
  { label: 'Automation', icon: '/images/badge-automation.svg' },
  { label: 'API Integrations', icon: '/images/badge-api.svg' },
  { label: 'Vue & React', icon: '/images/badge-react.svg' },
  { label: 'Serverless Architecture', icon: '/images/badge-security.svg' },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="hero">
    <GridBackground />
    <div class="hero-inner section-container">
      <div class="hero-row">
        <div class="hero-content">
          <p class="hero-label">Available for Projects</p>
          <h1 class="hero-title">
            Senior Developer.<br />
            <span class="hero-accent">Technical Leader.</span>
          </h1>
          <p class="hero-subtitle">
            Experienced developer with over {years} years of engineering experience. Tailored solutions for automation, data visualization, alerts and notifications, scalable architecture, rapid deployment, and more for your enterprise needs.
          </p>
          <div class="hero-actions">
            <a href="/#contact" class="btn-primary">Let's Talk</a>
            <a href="/#work" class="btn-outline">See My Work</a>
          </div>
        </div>
        <div class="hero-wheel">
          <BadgeWheel items={badgeItems} checkmarkIcon="/images/badge-checkmark.svg" />
        </div>
      </div>
    </div>
    <!-- Mobile marquee (BadgeWheel hides desktop version internally, but we need a second instance outside the hidden wrapper) -->
    <div class="hero-marquee-mobile">
      <BadgeWheel items={badgeItems} />
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="section-container">
      <div class="about-row">
        <div class="about-photo">
          <Picture
            src={chuckPhoto}
            formats={['avif', 'webp']}
            loading="lazy"
            decoding="async"
            alt="Chuck Allen"
            class="about-img"
          />
        </div>
        <div class="about-content">
          <h2 class="section-title">Hi, I'm Chuck!</h2>
          <p>Over my career I've had the chance to work with agencies, startups, and enterprise teams across every phase of a project. I care about doing good work and building things that last.</p>
          <p>I take the time to understand what you're trying to accomplish and stick with it until it's done. I'd rather build a real working relationship than chase the next gig.</p>
          <p>Based in Colorado, available during US business hours. Calls, screen shares, Slack — whatever works for your team. White-label friendly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section">
    <div class="section-container">
      <h2 class="section-title">Your Team Deserves Better Tools</h2>
      <p class="section-subtitle">
        You shouldn't be held back by brittle integrations, manual processes, or architecture that can't keep up. Here's where I help.
      </p>
      <div class="services-grid">
        <div class="service-card card">
          <h3 class="service-name">Modern Frameworks</h3>
          <p class="service-desc">Astro, Next.js, Vue, React, Node — production-ready builds with performance baked in.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">API Integrations</h3>
          <p class="service-desc">Google APIs, ShipStation, payment gateways, Outscraper, and custom connectors that just work.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Data & Visualization</h3>
          <p class="service-desc">Dashboards, reporting, real-time data — turning complex datasets into clear, actionable interfaces.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Automation & Alerts</h3>
          <p class="service-desc">Workflows, notifications, scheduled tasks — eliminate repetitive work and catch issues before they escalate.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Scalable Architecture</h3>
          <p class="service-desc">Serverless, edge functions, Cloudflare Workers — built to handle growth without rearchitecting.</p>
        </div>
        <div class="service-card card">
          <h3 class="service-name">Technical Leadership</h3>
          <p class="service-desc">I manage projects end-to-end. Planning, execution, communication — your vision, delivered.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work / Portfolio -->
  <section id="work" class="section">
    <GridBackground blobColor="rgba(0,118,157,0.05)" />
    <div class="section-container">
      <h2 class="section-title">Selected Work</h2>
      <p class="section-subtitle">
        Case studies and demos coming soon.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <Contact
    site={site}
    title="Let's Build Something Together"
    subtitle="I'm available for new projects. Pick the way that works best for you."
  />
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 140px 0 80px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero {
      padding: 180px 0 120px;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 1024px) {
    .hero-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 60px;
    }
  }

  .hero-content {
    flex: 1;
  }

  .hero-wheel {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-wheel {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      min-height: 500px;
    }
  }

  .hero-marquee-mobile {
    position: relative;
    z-index: 1;
    margin-top: 2rem;
  }
  @media (min-width: 1024px) {
    .hero-marquee-mobile {
      display: none;
    }
  }

  .hero-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-accent-light);
    margin-bottom: 16px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: 36px;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 24px;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 48px; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 64px; }
  }

  .hero-accent {
    color: var(--color-accent-light);
  }

  .hero-subtitle {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 600px;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    .hero-subtitle { font-size: 18px; }
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ── Sections ── */
  .section {
    position: relative;
    padding: 64px 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .section {
      padding: 96px 0;
    }
  }

  .section-title {
    font-size: 30px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 36px; }
  }
  @media (min-width: 1024px) {
    .section-title { font-size: 48px; }
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 16px;
    max-width: 600px;
    margin-bottom: 48px;
  }
  @media (min-width: 768px) {
    .section-subtitle { font-size: 18px; }
  }

  /* ── Services Grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    padding: 24px;
    transition: border-color 0.2s ease;
  }
  .service-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .service-name {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .service-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* ── About ── */
  .about-row {
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .about-row {
      flex-direction: row;
      gap: 60px;
      align-items: center;
    }
  }

  .about-photo {
    flex-shrink: 0;
  }

  .about-img {
    width: 280px;
    height: auto;
    border-radius: 16px;
    border: 1px solid var(--color-border-light);
  }
  @media (min-width: 768px) {
    .about-img {
      width: 360px;
    }
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    color: var(--color-text-muted);
    font-size: 16px;
    line-height: 1.7;
  }
  @media (min-width: 768px) {
    .about-content { font-size: 17px; }
  }
</style>
